{
  "name": "@coffeetales.net/wasm2lang",
  "version": "0.0.0",
  "description": "CLI tool that transpiles WebAssembly modules into equivalent asm.js, PHP, or Java source code.",
  "main": "wasm2lang.js",
  "bin": {
    "wasm2lang": "wasm2lang.js"
  },
  "license": "Apache-2.0",
  "files": [
    "LICENSE",
    "README.md",
    "dist_artifacts/wasmxlang.js",
    "wasm2lang.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/COFFEETALES/wasm2lang.git"
  },
  "bugs": {
    "url": "https://github.com/COFFEETALES/wasm2lang/issues"
  },
  "homepage": "https://github.com/COFFEETALES/wasm2lang#readme",
  "dependencies": {
    "binaryen": "^129.0.0"
  },
  "scripts": {
    "closure-make": "java -jar ./node_modules/google-closure-compiler-java/compiler.jar --flagfile=scripts/closure.flags",
    "postclosure-make": "node postbuild/wasm2lang_pass_tests.js --artifact dist_artifacts/wasmxlang.js"
  },
  "devDependencies": {
    "google-closure-compiler": "^20260412.0.0"
  }
}
